# Required: database connection
# Local example:
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://postgres:postgres@localhost:5432/w4lkies
# Production example (managed Postgres):
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Alternative: if using Vercel Postgres integration, POSTGRES_URL is accepted.

# Required: auth
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Required: CORS (comma-separated)
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: API metadata
PROJECT_NAME=W4lkies API
PROJECT_DESCRIPTION=FastAPI backend for W4lkies
PROJECT_SUMMARY=Production environment
PROJECT_VERSION=0.1.0
PROJECT_LICENSE=Proprietary
PROJECT_LICENSE_URL=https://example.com/license

# Optional: mail (if not set, email sending is skipped)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER_NAME=W4lkies
